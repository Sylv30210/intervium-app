NODE_ENV=development
PORT=5000

# PostgreSQL : utilisez DATABASE_URL ou les variables DB_* ci-dessous.
# En production Neon, utilisez idéalement l'URL poolée pour l'application et
# l'URL directe pour les migrations.
# DATABASE_URL=postgresql://intervium:mot_de_passe@localhost:5432/intervium
# MIGRATION_DATABASE_URL=postgresql://intervium:mot_de_passe@localhost:5432/intervium
DB_HOST=localhost
DB_PORT=5432
DB_USER=intervium
DB_PASSWORD=change_me
DB_NAME=intervium
DB_POOL_MAX=10
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# À générer avec une valeur aléatoire longue (au moins 32 octets).
JWT_SECRET=change_me_with_a_long_random_secret

# Facultatif : origine du frontend si celui-ci est hébergé séparément.
# FRONTEND_ORIGIN=https://app.exemple.fr

# Dossier persistant des médias en production (disque Render/Fly).
# UPLOADS_DIRECTORY=/var/data/uploads
